{
  "expo": {
    "name": "Aeonvera",
    "slug": "aeonvera",
    "scheme": "aeonvera",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#050505"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aeonvera.app"
    },
    "android": {
      "package": "com.aeonvera.app",
      "adaptiveIcon": {
        "backgroundColor": "#050505"
      }
    },
    "extra": {
      "webUrl": "https://www.aeonvera.com"
    },
    "plugins": [
      "expo-notifications",
      "expo-secure-store"
    ]
  }
}
