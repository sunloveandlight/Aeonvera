{
  "expo": {
    "name": "Aeonvera",
    "slug": "aeonvera",
    "scheme": "aeonvera",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#050505"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aeonvera.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.aeonvera.app"
    },
    "extra": {
      "webUrl": "https://www.aeonvera.com",
      "eas": {
        "projectId": "273e8224-7c4f-4753-a00a-ec3d329f2f6b"
      }
    },
    "plugins": [
      [
        "expo-calendar",
        {
          "calendarPermission": "Allow Aeonvera to add and manage protocol blocks in your calendar.",
          "writeOnlyCalendarPermission": "Allow Aeonvera to add protocol blocks to your calendar.",
          "writeOnlyAccess": true
        }
      ],
      "expo-notifications",
      "expo-secure-store"
    ],
    "owner": "aeonvera"
  }
}
